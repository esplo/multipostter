{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "files": {
    "includes": [
      "bin/**/*.ts",
      "lambda/**/*.ts",
      "lib/**/*.ts",
      "!bin/mpost.ts",
      "!**/*.d.ts",
      "!**/*.js",
      "!**/node_modules",
      "!**/cdk.out",
      "!**/dist"
    ]
  }
}
